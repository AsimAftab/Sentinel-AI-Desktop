{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentinel AI",
  "version": "0.6.0",
  "identifier": "ai.sentinel.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sentinel AI",
        "width": 1150,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "licenseFile": "LICENSE.txt",
    "resources": [
      "binaries/sentinel-core"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCODIzQ0ExODVERjQwMkQKUldRdFFOK0ZvVHlDTzZrOHE5eWFTcjNRb09vdFdXV29IaVRhUWhaYU9rWGdmVVAyTERrMFZlRm4K",
      "endpoints": [
        "https://github.com/AsimAftab/Sentinel-AI-Desktop/releases/latest/download/latest.json"
      ]
    }
  }
}