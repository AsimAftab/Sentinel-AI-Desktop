# Sentinel AI Backend - Environment Variables Template
# Copy this file to .env and fill in your API keys

# =============================================================================
# WAKE WORD DETECTION
# =============================================================================
# Picovoice Porcupine API Key (Required for wake word detection)
# Get your free key at: https://console.picovoice.ai/
PORCUPINE_KEY=your_porcupine_api_key_here

# Wake word sensitivity (0.0 - 1.0, higher = more sensitive but more false positives)
WAKE_WORD_SENSITIVITY=0.7

# Comma-separated wake word model paths (for multiple wake words)
WAKE_WORD_PATHS=src/wakeword/Sentinel_en_windows_v3_0_0.ppn

# =============================================================================
# SPEECH RECOGNITION
# =============================================================================
# Speech recognition language (BCP-47 code)
STT_LANGUAGE=en-US

# Energy threshold for speech detection (higher = less sensitive to quiet speech)
# Leave blank for automatic calibration
STT_ENERGY_THRESHOLD=

# Pause threshold in seconds (how long of silence marks end of phrase)
STT_PAUSE_THRESHOLD=

# Enable continuous listening mode (skips wake word, always listening)
CONTINUOUS_LISTENING=false

# =============================================================================
# AI MODEL - MULTIPLE LLM PROVIDERS
# =============================================================================
# Primary LLM Provider Selection (azure, ollama, openai, zhipu)
LLM_PROVIDER=azure

# Global Temperature Setting (0.0 - 2.0)
LLM_TEMPERATURE=0

# Enable Fallback Provider (true/false) - Automatically switch if primary fails
LLM_FALLBACK_ENABLED=false

# =============================================================================
# AZURE OPENAI CONFIGURATION
# =============================================================================
# Azure OpenAI Configuration
AZURE_OPENAI_ENABLED=true
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name_here
AZURE_OPENAI_API_VERSION=2023-05-15

# =============================================================================
# OLLAMA (LOCAL LLM) CONFIGURATION
# =============================================================================
# Ollama Configuration - For local LLM inference
OLLAMA_ENABLED=false
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120.0

# =============================================================================
# OPENAI CONFIGURATION
# =============================================================================
# OpenAI Configuration
OPENAI_ENABLED=false
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# =============================================================================
# ZHIPU AI (GLM) CONFIGURATION
# =============================================================================
# Zhipu AI Configuration - For GLM model inference (OpenAI-compatible API)
# Get your API key at: https://open.bigmodel.cn/
ZHIPU_ENABLED=false
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash
ZHIPU_BASE_URL=https://api.z.ai/api/coding/paas/v4

# =============================================================================
# AGENT-SPECIFIC LLM ASSIGNMENTS (OPTIONAL)
# =============================================================================
# Assign specific LLM providers to individual agents
# Leave blank to use the primary provider for all agents
# Options: azure, ollama, openai, zhipu (must be enabled above)
LLM_AGENT_BROWSER=
LLM_AGENT_MUSIC=
LLM_AGENT_MEETING=
LLM_AGENT_SYSTEM=
LLM_AGENT_PRODUCTIVITY=
LLM_AGENT_NOTES=
LLM_AGENT_EMAIL=
LLM_AGENT_SUPERVISOR=

# =============================================================================
# PER-AGENT TEMPERATURE OVERRIDES (OPTIONAL)
# =============================================================================
# Fine-tune creativity/determinism per agent (0.0 = deterministic, 1.0 = creative)
# Leave blank to use the global LLM_TEMPERATURE for all agents
# Recommended values:
#   Supervisor: 0   (must be precise when routing — no creativity needed)
#   Browser:    0   (factual web lookups — deterministic is best)
#   System:     0   (system commands must be exact)
#   Meeting:    0   (calendar operations must be reliable)
#   Email:      0.2 (slight creativity helps with drafting)
#   Music:      0.3 (some variation in song/playlist suggestions)
#   Notes:      0.2 (natural language when creating note content)
#   Productivity: 0 (timers/alarms are deterministic)
LLM_AGENT_BROWSER_TEMPERATURE=
LLM_AGENT_MUSIC_TEMPERATURE=
LLM_AGENT_MEETING_TEMPERATURE=
LLM_AGENT_SYSTEM_TEMPERATURE=
LLM_AGENT_PRODUCTIVITY_TEMPERATURE=
LLM_AGENT_NOTES_TEMPERATURE=
LLM_AGENT_EMAIL_TEMPERATURE=
LLM_AGENT_SUPERVISOR_TEMPERATURE=

# =============================================================================
# WEB SEARCH
# =============================================================================
# Tavily API Key (Required for web search functionality)
# Get your free key at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# MUSIC INTEGRATION - SPOTIFY
# =============================================================================
# Spotify API Credentials (Required for Spotify music playback)
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# =============================================================================
# TEXT-TO-SPEECH - ELEVENLABS
# =============================================================================
# ElevenLabs API Key (Required for voice responses)
# Get your free key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice ID (Optional - defaults to Sarah)
# Popular voices:
#   - EXAVITQu4vr4xnSDxMaL (Sarah - Female, warm and friendly)
#   - 21m00Tcm4TlvDq8ikWAM (Rachel - Female, calm and professional)
#   - ErXwobaYiN019PkySvjV (Antoni - Male, friendly and conversational)
#   - VR6AewLTigWG4xSOukaG (Arnold - Male, deep and authoritative)
#   - pNInz6obpgDQGcFmaJgB (Adam - Male, clear and engaging)
# To see all available voices, run: python src/utils/text_to_speech.py
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Enable/Disable Text-to-Speech (true/false)
TTS_ENABLED=true

# Fallback to pyttsx3 (offline, free) when ElevenLabs fails (true/false)
TTS_FALLBACK_ENABLED=true

# pyttsx3 speech rate (words per minute, default 175)
TTS_FALLBACK_RATE=175

# =============================================================================
# LYRICS (OPTIONAL)
# =============================================================================
# Genius API Token (Optional - for displaying full lyrics text)
# Without this, lyrics will open in browser instead
# Get free token at: https://genius.com/api-clients
GENIUS_API_TOKEN=your_genius_api_token_here

# =============================================================================
# GOOGLE MEET & CALENDAR (OPTIONAL)
# =============================================================================
# Google OAuth credentials for Meeting agent
# Download credentials.json from Google Cloud Console
# Place file in: Sentinel-AI-Backend/credentials.json
# The first time you create a meeting, you'll authenticate via browser
# token.json will be auto-generated and saved

# Optional: Custom paths (leave blank to use defaults)
GOOGLE_CREDENTIALS_PATH=
GOOGLE_TOKEN_PATH=

# =============================================================================
# DATABASE - MONGODB (OPTIONAL - for Agent Memory)
# =============================================================================
# MongoDB Connection String (Required for persistent agent memory)
# The backend shares the same MongoDB instance as the frontend
# Uses the same database configured in Sentinel-AI-Frontend/.env
# If not set, agent memory falls back to in-memory storage (non-persistent)
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=sentinel_ai_db
MONGODB_COLLECTION_TOKENS=service_tokens

# =============================================================================
# LLM RESPONSE CACHING (OPTIONAL)
# =============================================================================
# Enable in-memory LLM response caching (reduces API calls for repeated queries)
LLM_CACHE_ENABLED=false

# =============================================================================
# LANGSMITH DEBUGGING (OPTIONAL)
# =============================================================================
# LangSmith provides detailed tracing for LangGraph agents
# Get your free API key at: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=sentinel-ai-desktop-backend
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
